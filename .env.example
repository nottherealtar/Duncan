# Developer API key from https://developer.clashroyale.com (NOT the in-game Settings → API Token)
CLASH_ROYALE_API_TOKEN=

# Optional: override proxy URL. On Vercel, RoyaleAPI proxy is used automatically (Vercel IPs cannot be whitelisted).
# CLASH_ROYALE_PROXY_URL=https://proxy.royaleapi.dev/v1

# Optional: Secure the daily cron endpoint
CRON_SECRET=
